# F087 e2e_live 环境变量模板（plan §7.2 锁定的 OCTOAGENT_E2E_* 命名规范）
#
# 用法：
#   cp tests/fixtures/local-instance/.env.e2e.template tests/fixtures/local-instance/.env.e2e
#   # 编辑 .env.e2e 填入本机有效值（**不会入仓**，由 .env.* gitignore 兜底）
#
# 命名约定：仅 e2e 测试代码内部使用 OCTOAGENT_E2E_* 前缀；生产代码不读这些变量。

# 强制使用真实 LLM（默认 1）。设 0 → e2e 应 SKIP（保留给 CI 占位场景）
OCTOAGENT_E2E_REAL_LLM=1

# Perplexity API Key（域 #5 真实 MCP 调用用）
# 测试 fixture 从这里读，再通过 mcp.install(env=...) 显式注入子进程
# 不通过 _SAFE_ENV_KEYS 透传（保持 Constitution #5 Least Privilege）
OCTOAGENT_E2E_PERPLEXITY_API_KEY=

# e2e 日志输出根目录；不设默认 ~/.octoagent/logs/e2e
OCTOAGENT_E2E_LOG_DIR=
