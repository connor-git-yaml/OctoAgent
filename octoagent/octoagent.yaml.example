# OctoAgent 统一配置文件（示例）
# 由 octo config 管理，安全纳入版本管理
#
# NEVER 在此文件存储 API Key 明文 — 使用 api_key_env 存储环境变量名
# API Key 明文由 .env 管理（已在 .gitignore，模板见 .env.example）
#
# 快速开始：
#   cp octoagent.yaml.example octoagent.yaml
#   octo config provider add openrouter   # 添加 Provider 并配置 API Key
#   octo setup                             # 保存配置并验证 Provider 直连

config_version: 1
updated_at: "2026-03-08"

# Provider 列表 — 每个 Provider 对应一个 LLM 服务商
# auth_type: api_key（API Key 认证）或 oauth（OAuth 认证）
# api_key_env: 凭证所在的环境变量名（仅存名称，不存实际值）
# enabled: false 时不参与 Provider 路由，但配置保留（可逆）
providers:
  - id: openrouter
    name: "OpenRouter"
    auth_type: api_key
    api_key_env: OPENROUTER_API_KEY   # 实际值在 CredentialStore 或 .env 中
    enabled: true

  # 多 Provider 示例（按需取消注释）
  # - id: anthropic
  #   name: "Anthropic"
  #   auth_type: api_key
  #   api_key_env: ANTHROPIC_API_KEY
  #   enabled: false
  #
  # - id: openai
  #   name: "OpenAI"
  #   auth_type: api_key
  #   api_key_env: OPENAI_API_KEY
  #   enabled: false
  #
  # - id: openai-codex
  #   name: "OpenAI Codex (ChatGPT Pro OAuth)"
  #   auth_type: oauth
  #   api_key_env: OPENAI_API_KEY
  #   enabled: true

# 模型别名映射 — 将用户可见别名绑定到具体 Provider 和模型字符串
# provider: 对应 providers[].id（引用完整性，octo config 会自动校验）
# model: 传递给 Provider adapter 的完整模型字符串
# 内置别名：main（主力模型）和 cheap（低成本模型，用于 octo doctor --live ping）
model_aliases:
  main:
    provider: openrouter
    model: "openrouter/auto"
    description: "主力对话模型（高质量请求）"
  cheap:
    provider: openrouter
    model: "openrouter/auto"
    description: "低成本模型（用于 octo doctor --live ping）"

  # 自定义别名示例（按需取消注释）
  # fast:
  #   provider: openrouter
  #   model: "openrouter/auto"
  #   description: "快速响应模型（低延迟任务）"
  #
  # OpenAI Codex 示例（GPT-5.4）
  # main:
  #   provider: openai-codex
  #   model: "gpt-5.4"
  #   description: "主力模型（GPT-5.4，深度推理）"
  #   thinking_level: xhigh
  # cheap:
  #   provider: openai-codex
  #   model: "gpt-5.4"
  #   description: "低成本模型（GPT-5.4，轻量推理）"
  #   thinking_level: low

# Front-door 边界 — 保护 owner-facing API（Control Plane / Tasks / Ops / Chat / SSE）
# mode:
#   loopback       仅允许本机直连（默认；只适合本机使用）
#   bearer         要求所有 owner-facing API 提供 Bearer Token
#   trusted_proxy  仅允许受信代理来源 IP + 共享 header token
# bearer_token_env / trusted_proxy_token_env 只存环境变量名，不存凭证值。
front_door:
  mode: loopback
  bearer_token_env: OCTOAGENT_FRONTDOOR_TOKEN
  trusted_proxy_header: X-OctoAgent-Proxy-Auth
  trusted_proxy_token_env: OCTOAGENT_TRUSTED_PROXY_TOKEN
  trusted_proxy_cidrs:
    - 127.0.0.1/32
    - ::1/128

# 安全策略 — 出站网络等
# allow_private_urls:
#   false（默认）：拦截 web.fetch / browser.* 访问私网/内部 IP（防 SSRF）。
#   true：仅在 DNS 把外域解析到内网/benchmark 段的特殊部署才置 true。
#   ⚠️ 云元数据端点（169.254.169.254 等）即便 true 也【永远】拦截。
#   可被环境变量 OCTOAGENT_ALLOW_PRIVATE_URLS 覆盖（优先级更高）。
security:
  allow_private_urls: false
