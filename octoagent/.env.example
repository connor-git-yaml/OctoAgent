# OctoAgent 通用配置示例
# 复制为 .env 并根据需要调整
#
# 对齐 contracts/deployment.md SS3.1

# ============================================================
# Provider 直连
# ============================================================
# 真实 Provider 默认直接启用，无需设置运行模式。开发/测试如需 Echo，取消下一行注释。
# OCTOAGENT_LLM_MODE=echo

# Provider 凭证（按 octoagent.yaml 中的 api_key_env 名称配置）
OPENROUTER_API_KEY=replace-with-your-provider-key

# LLM 调用超时（秒）
OCTOAGENT_LLM_TIMEOUT_S=30
