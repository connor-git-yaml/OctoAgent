#!/usr/bin/env bash
# F087 P3 T-P3-7/8/10: pre-commit hook 跑 e2e_smoke 套件，commit 前 ≤ 180s 反馈。
# 附加：agent-config 同步检查——防 CLAUDE.md / AGENTS.md 与 .agent-config 源脱节
#       （快速、确定性、无环境依赖；先于 e2e 跑；bypass: SKIP_SYNC_CHECK=1）。
# F087 P3 fixup#3 (Codex finding-3): portable timeout——不依赖 macOS 上需要
# brew install coreutils 才有的 timeout 命令；改用内嵌 python3 watchdog（标准库
# subprocess + signal，跨 macOS / Linux 一致行为）。
# F141（pr lane）：
#   - pytest 表达式 e2e_smoke → "e2e_smoke or e2e_scripted"（脚本化决策环 +
#     审批全链 + prompt 预算护栏进 commit 反馈环；实测 +~4s，远低于 180s 预算）
#   - quarantine 过期强制恒跑（Codex final M1）：pr 是 canonical 门禁入口，
#     过期条目 commit 时即咬人（schema 或过期 → 阻断）
#   - change-policy 路由（保守两条）：①纯 docs 提速——staged 全部 ∈
#     {docs/**, **/*.md, .specify/**} 时跳过 e2e 与前端检查（sync-check 恒跑）；
#     staged 含 attestation-checklist.md 时附跑解析校验
#     ②生产 src 改动无伴随测试 → WARNING（不阻断，保守起步）
#
# 行为：
#   - SKIP_E2E=1 git commit ...      → 跳过 e2e（sync/前端/路由校验仍跑）
#   - 纯 docs staged                  → 跳过 e2e + 前端（输出 fastpath 行）
#   - 否则                            → cd octoagent && uv run python -m pytest
#                                        -m "e2e_smoke or e2e_scripted" -q
#                                        --maxfail=1 总 timeout 180s
#
# 失败输出（FR-31）：3 行核心 + 日志路径，不刷屏；不全量 dump LLM 响应。
#
# bypass 文档：
#   - agent-config 同步失败 → 跑 ./repo-scripts/sync-agent-config.sh 再 git add；
#     紧急可 SKIP_SYNC_CHECK=1 git commit
#   - 紧急 commit 用 SKIP_E2E=1 git commit -m "..."（注意：release lane 中无效，
#     `lane.py release` 不消费该 env——F141 D4）
#   - 网络不可用 / OAuth profile 失效时 e2e 自然 SKIP（不阻断 commit）
#
# 安装：在 worktree 根执行 `make install-hooks` 或
#       `git config core.hooksPath .githooks`

set -e

# ---- agent-config 同步检查（先于一切：快速 + 确定性 + 无环境依赖）----
# 防止：改了 .agent-config/shared.md 或 templates/ 忘了重新生成；或直接改了
# 自动生成的 CLAUDE.md / AGENTS.md。刻意放在 SKIP_E2E bypass 之前——同步漂移
# 与 e2e 环境问题是独立关注点，SKIP_E2E=1 不应顺带跳过同步校验。
if [[ "${SKIP_SYNC_CHECK:-0}" != "1" ]]; then
  SYNC_REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
  SYNC_SCRIPT="${SYNC_REPO_ROOT}/repo-scripts/sync-agent-config.sh"
  if [[ -x "${SYNC_SCRIPT}" ]]; then
    if ! "${SYNC_SCRIPT}" --check >/dev/null 2>&1; then
      echo "[SYNC FAIL] CLAUDE.md / AGENTS.md 与 .agent-config 源不一致"
      echo "  原因:   改了 shared.md / templates 未重新生成，或直接改了自动生成文件"
      echo "  修复:   ./repo-scripts/sync-agent-config.sh  然后 git add CLAUDE.md AGENTS.md"
      echo "  bypass: SKIP_SYNC_CHECK=1 git commit"
      exit 1
    fi
  fi
fi

# ---- F141: quarantine 过期强制（恒跑，先于 docs fastpath——Codex final M1）----
# pr 是 canonical 门禁入口：过期条目必须在 commit 时就咬人，而不是等 CI / lane。
# stdlib python3 + 空 manifest <100ms；schema 损坏或过期 → 阻断 commit。
Q_REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
Q_SCRIPT="${Q_REPO_ROOT}/repo-scripts/check-quarantine.py"
Q_MANIFEST="${Q_REPO_ROOT}/octoagent/tests/quarantine.json"
if [[ -f "${Q_SCRIPT}" && -f "${Q_MANIFEST}" ]]; then
  if ! python3 "${Q_SCRIPT}" --manifest "${Q_MANIFEST}" --enforce-review-date; then
    echo "[QUARANTINE FAIL] quarantine manifest 校验未过（schema 或过期条目需复查）"
    echo "  详情: python3 repo-scripts/check-quarantine.py --enforce-review-date"
    echo "  处置: 治好删条目，或带新证据更新 review_after（见 octoagent/tests/AGENTS.md §5）"
    exit 1
  fi
fi

# ---- F141: change-policy 路由（git diff --cached --name-only 前缀路由）----
# 保守两条（spec 件3；不做复杂 area 矩阵）：
#   ① 纯 docs 提速：staged 全部 ∈ {docs/**, **/*.md, .specify/**} → 跳过
#      e2e_smoke + 前端检查（sync-check 已在上方恒跑——CLAUDE.md/AGENTS.md 本身
#      是 .md，模板漂移由它兜底）；
#      gate 机器资产例外：staged 含 octoagent/tests/quarantine.json → 附跑
#      check-quarantine（stdlib python3 直调）；含 attestation-checklist.md →
#      附跑 check-attestation 解析校验（须 venv PyYAML，经 uv run --no-sync）
#   ② missing-test 警告：staged 含生产 src（packages/*/src / apps/gateway/src /
#      frontend/src，排除测试文件）且无任何 staged 测试文件 → WARNING 不阻断
CP_REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
STAGED_FILES="$(git diff --cached --name-only 2>/dev/null || true)"
DOCS_ONLY=0

if [[ -n "${STAGED_FILES}" ]]; then
  DOCS_ONLY=1
  HAS_PROD_SRC=0
  HAS_TEST_FILE=0
  while IFS= read -r f; do
    [[ -z "${f}" ]] && continue
    # ① docs-only 判定
    case "${f}" in
      docs/*|.specify/*|*.md) ;;
      *) DOCS_ONLY=0 ;;
    esac
    # ② missing-test 信号采集
    case "${f}" in
      *.test.*|*/tests/*|*/test_*|*_test.*) HAS_TEST_FILE=1 ;;
      octoagent/packages/*/src/*|octoagent/apps/gateway/src/*|octoagent/frontend/src/*)
        HAS_PROD_SRC=1 ;;
    esac
    # gate 机器资产附加校验（staged 触发；fastpath 下同样生效）
    # 注：quarantine.json 无需 staged 分支——上方恒跑段已含 schema+过期全量校验
    case "${f}" in
      docs/codebase-architecture/attestation-checklist.md)
        if ! (cd "${CP_REPO_ROOT}/octoagent" && uv run --no-sync python \
             "${CP_REPO_ROOT}/repo-scripts/check-attestation.py" \
             --checklist "${CP_REPO_ROOT}/docs/codebase-architecture/attestation-checklist.md" \
             >/dev/null 2>&1); then
          echo "[ATTESTATION FAIL] attestation-checklist.md yaml block 解析/schema 校验未过"
          echo "  详情: uv run --no-sync python repo-scripts/check-attestation.py"
          exit 1
        fi
        ;;
    esac
  done <<< "${STAGED_FILES}"

  if [[ ${HAS_PROD_SRC} -eq 1 && ${HAS_TEST_FILE} -eq 0 ]]; then
    echo "[MISSING-TEST WARN] 本次 staged 含生产 src 改动但无伴随测试文件"
    echo "  （警告不阻断；CI changed-lines coverage 门会按新增行 ≥90% 机械把关）"
  fi

  if [[ ${DOCS_ONLY} -eq 1 ]]; then
    echo "[LANE] docs-only fastpath: staged 均为 docs/**、*.md、.specify/** → 跳过 e2e + 前端检查"
    exit 0
  fi
fi

# ---- F137: 前端复杂度检查（亚秒级 node 脚本；先于 SKIP_E2E——前端护栏与 e2e
#      环境是独立关注点，SKIP_E2E=1 不应顺带跳过前端闸）----
# bypass: SKIP_FRONTEND_CHECK=1 git commit（照 SKIP_E2E 范式，紧急逃生门）
# node 缺失 → 降级 SKIP 不阻断 commit（Constitution #6；CI 侧仍会跑到）
if [[ "${SKIP_FRONTEND_CHECK:-0}" != "1" ]]; then
  FE_REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
  FE_CHECK_SCRIPT="${FE_REPO_ROOT}/repo-scripts/check-frontend-complexity.mjs"
  if ! command -v node >/dev/null 2>&1; then
    echo "[FRONTEND SKIP] node 不可用，复杂度检查降级跳过（CI 会兜底）"
  elif [[ -f "${FE_CHECK_SCRIPT}" ]]; then
    if ! node "${FE_CHECK_SCRIPT}" >/dev/null 2>&1; then
      echo "[FRONTEND FAIL] 前端复杂度检查未通过"
      echo "  详情:   node repo-scripts/check-frontend-complexity.mjs"
      echo "  修复:   拆分超限文件，或（F143 ratchet 范围内）调整 explicitLimits"
      echo "  bypass: SKIP_FRONTEND_CHECK=1 git commit"
      exit 1
    fi
    echo "[FRONTEND PASS] 复杂度检查通过"
  fi
fi

# ---- bypass 路径 ----
if [[ "${SKIP_E2E:-0}" == "1" ]]; then
  echo "[E2E] skipped via SKIP_E2E=1"
  exit 0
fi

# ---- 定位 repo / octoagent 子目录 ----
REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
OCTOAGENT_DIR="${REPO_ROOT}/octoagent"

if [[ ! -d "${OCTOAGENT_DIR}" ]]; then
  echo "[E2E SKIP] octoagent/ 子目录不存在 (REPO_ROOT=${REPO_ROOT})"
  exit 0
fi

# ---- 日志路径 ----
LOG_DIR="${HOME}/.octoagent/logs/e2e"
mkdir -p "${LOG_DIR}"
TIMESTAMP="$(date +%Y%m%d-%H%M%S)"
LOG_FILE="${LOG_DIR}/pre-commit-${TIMESTAMP}.log"

# ---- 跑 e2e_smoke + e2e_scripted（180s portable watchdog）----
# F141：纳入 e2e_scripted（脚本化决策环，F138 marker 预留「F141 归入 pr lane」）。
# 用 python3 标准库实现 watchdog（subprocess + SIGTERM/SIGKILL 升级），
# 不依赖 macOS 默认无的 timeout / gtimeout 命令。
TIMEOUT_SECONDS=180

set +e
python3 - "${OCTOAGENT_DIR}" "${LOG_FILE}" "${TIMEOUT_SECONDS}" <<'PYWATCHDOG' >/dev/null 2>&1
import os
import signal
import subprocess
import sys
import time

octoagent_dir, log_file, timeout_s = sys.argv[1], sys.argv[2], int(sys.argv[3])

# 起子进程跑 pytest（写到 log_file）
#
# 基础设施修复（hermetic 调用）：用 `uv run python -m pytest` 而非裸 `uv run pytest`。
# 根因：裸 `pytest` 是 console-script，会逃出 venv——venv 的 .venv/bin/pytest shebang
# 可能指向已删 worktree 的解释器（共享 venv symlink 设计的副作用），uv 退化到 PATH 上
# 的全局 pytest（Homebrew python3.14）。该解释器 site-packages 里有 SWE-bench 残留的
# __editable__ 安装（SWE-L003 pytest src / SWE-L002 astropy），既把 bench worktree
# 路径塞进 sys.path，又缺 aiosqlite → ConftestImportFailure，逼迫每次 SKIP_E2E。
# `python -m pytest` 强制用 venv 解释器（3.12，干净 sys.path + aiosqlite 齐全），
# 绕开 console-script shebang 与 PATH 回退；PYTHONNOUSERSITE=1 再防 user-site
# editable 污染（venv 默认已禁 user-site，双保险）。
hermetic_env = {**os.environ, "PYTHONNOUSERSITE": "1"}
with open(log_file, "wb") as logf:
    proc = subprocess.Popen(
        ["uv", "run", "python", "-m", "pytest", "-m", "e2e_smoke or e2e_scripted", "--maxfail=1", "-q"],
        cwd=octoagent_dir,
        stdout=logf,
        stderr=subprocess.STDOUT,
        env=hermetic_env,
        # 新建独立 process group，便于一次性 SIGKILL 整个子树
        preexec_fn=os.setsid,
    )

deadline = time.monotonic() + timeout_s
while True:
    rc = proc.poll()
    if rc is not None:
        sys.exit(rc)
    if time.monotonic() >= deadline:
        # 先 SIGTERM 整 process group，等 5s，再 SIGKILL
        try:
            os.killpg(os.getpgid(proc.pid), signal.SIGTERM)
        except ProcessLookupError:
            pass
        try:
            proc.wait(timeout=5)
        except subprocess.TimeoutExpired:
            try:
                os.killpg(os.getpgid(proc.pid), signal.SIGKILL)
            except ProcessLookupError:
                pass
            proc.wait()
        # exit code 124 与 GNU timeout 一致语义
        sys.exit(124)
    time.sleep(0.5)
PYWATCHDOG
EXIT_CODE=$?
set -e

# ---- 处理结果 ----
if [[ ${EXIT_CODE} -eq 0 ]]; then
  # 成功：单行总结 + 日志路径
  PASS_LINE="$(grep -E "^[0-9]+ passed" "${LOG_FILE}" | tail -1 || echo "smoke ok")"
  echo "[E2E PASS] ${PASS_LINE}"
  echo "  log: ${LOG_FILE}"
  exit 0
fi

# ---- 失败：3 行核心 + 日志路径（FR-31 / T-P3-8 格式）----
if [[ ${EXIT_CODE} -eq 124 ]]; then
  # watchdog 超时（与 GNU timeout 一致语义）
  echo "[E2E FAIL] timeout=${TIMEOUT_SECONDS}s (portable watchdog)"
  echo "  expected: smoke + scripted 全 PASS 且 ≤ ${TIMEOUT_SECONDS}s 内完成"
  echo "  actual:   pytest 子进程超时被 SIGKILL（process group 树清理）"
  echo "  log: ${LOG_FILE}"
  echo "  bypass: SKIP_E2E=1 git commit"
  exit 1
fi

# 抓第一个失败的测试节点
FAILED_NODE="$(grep -E "^FAILED " "${LOG_FILE}" | head -1 | awk '{print $2}' || echo "<unknown>")"
DOMAIN_NAME="$(basename "${FAILED_NODE}" 2>/dev/null | cut -d':' -f1 || echo "<unknown>")"
# 抓第一行 AssertionError 描述（不全 dump）
EXPECTED_LINE="$(grep -E "AssertionError|assert " "${LOG_FILE}" | head -1 | sed 's/^[[:space:]]*//' | cut -c1-200 || echo "<no assertion captured>")"

echo "[E2E FAIL] domain=${DOMAIN_NAME}"
echo "  expected: smoke + scripted 全 PASS"
echo "  actual:   ${EXPECTED_LINE}"
echo "  log: ${LOG_FILE}"
echo "  bypass: SKIP_E2E=1 git commit"

exit 1
